<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Paramixel PMD Ruleset"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">
    
    <description>
        PMD ruleset for Paramixel project.
        Focuses on detecting dead code, unused code, and code quality issues.
        All 8 PMD 7.x rule categories are enabled. Exclusions are limited to:
        - Style rules that conflict with the project's established conventions
        - Rules that produce false positives for the framework's design patterns
          (thread pool management, safe listener wrapping, etc.)
    </description>
    
    <!-- Best Practices Category -->
    <rule ref="category/java/bestpractices.xml">
        <exclude name="GuardLogStatement"/>
        <exclude name="SystemPrintln"/>
        <exclude name="MissingOverride"/>
        <exclude name="LooseCoupling"/>
        <exclude name="UnitTestShouldUseTestAnnotation"/>
        <exclude name="RelianceOnDefaultCharset"/>
        <exclude name="AvoidReassigningParameters"/>
        <exclude name="PreserveStackTrace"/>
        <exclude name="ImplicitFunctionalInterface"/>
        <exclude name="UnusedPrivateField"/>
    </rule>
    
    <!-- Code Style -->
    <rule ref="category/java/codestyle.xml">
        <exclude name="LongVariable"/>
        <exclude name="OnlyOneReturn"/>
        <exclude name="ShortVariable"/>
        <exclude name="ShortMethodName"/>
        <exclude name="MethodArgumentCouldBeFinal"/>
        <exclude name="LocalVariableCouldBeFinal"/>
        <exclude name="UseExplicitTypes"/>
        <exclude name="FieldNamingConventions"/>
        <exclude name="ClassNamingConventions"/>
        <exclude name="AtLeastOneConstructor"/>
        <exclude name="UnnecessaryConstructor"/>
        <exclude name="CommentDefaultAccessModifier"/>
        <exclude name="LinguisticNaming"/>
        <exclude name="ShortClassName"/>
        <exclude name="ConfusingTernary"/>
        <exclude name="CallSuperInConstructor"/>
        <exclude name="LambdaCanBeMethodReference"/>
        <exclude name="FieldDeclarationsShouldBeAtStartOfClass"/>
        <exclude name="UseUnderscoresInNumericLiterals"/>
        <exclude name="ControlStatementBraces"/>
        <exclude name="EmptyMethodInAbstractClassShouldBeAbstract"/>
        <exclude name="PrematureDeclaration"/>
    </rule>
    
    <!-- Design -->
    <rule ref="category/java/design.xml">
        <exclude name="LawOfDemeter"/>
        <exclude name="UseUtilityClass"/>
        <exclude name="LoosePackageCoupling"/>
        <exclude name="ClassWithOnlyPrivateConstructorsShouldBeFinal"/>
        <exclude name="TooManyMethods"/>
        <exclude name="ExcessiveImports"/>
        <exclude name="GodClass"/>
        <exclude name="CognitiveComplexity"/>
        <exclude name="CyclomaticComplexity"/>
        <exclude name="ExceptionAsFlowControl"/>
        <exclude name="SignatureDeclareThrowsException"/>
        <exclude name="AvoidThrowingRawExceptionTypes"/>
        <exclude name="DataClass"/>
        <exclude name="SimplifyBooleanReturns"/>
        <exclude name="AvoidDeeplyNestedIfStmts"/>
        <exclude name="MutableStaticState"/>
        <exclude name="SwitchDensity"/>
        <exclude name="NPathComplexity"/>
    </rule>
    <rule ref="category/java/design.xml/CouplingBetweenObjects">
        <properties>
            <property name="threshold" value="50"/>
        </properties>
    </rule>
    <rule ref="category/java/design.xml/NcssCount">
        <properties>
            <property name="methodReportLevel" value="100"/>
        </properties>
    </rule>
    
    <!-- Error Prone -->
    <rule ref="category/java/errorprone.xml">
        <exclude name="AvoidDuplicateLiterals"/>
        <exclude name="AvoidFieldNameMatchingTypeName"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="AvoidCatchingThrowable"/>
        <exclude name="AvoidCatchingGenericException"/>
        <exclude name="CloseResource"/>
        <exclude name="MissingSerialVersionUID"/>
        <exclude name="UseProperClassLoader"/>
        <exclude name="NullAssignment"/>
        <exclude name="AssignmentInOperand"/>
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <exclude name="TestClassWithoutTestCases"/>
        <exclude name="AvoidInstanceofChecksInCatchClause"/>
        <exclude name="CompareObjectsWithEquals"/>
        <exclude name="MissingStaticMethodInNonInstantiatableClass"/>
        <exclude name="DoNotTerminateVM"/>
        <exclude name="ConstructorCallsOverridableMethod"/>
    </rule>
    
    <!-- Documentation -->
    <rule ref="category/java/documentation.xml">
        <exclude name="CommentRequired"/>
        <exclude name="CommentSize"/>
        <exclude name="UncommentedEmptyMethodBody"/>
        <exclude name="UncommentedEmptyConstructor"/>
    </rule>
    
    <!-- Multithreading -->
    <rule ref="category/java/multithreading.xml">
        <exclude name="DoNotUseThreads"/>
        <exclude name="AvoidThreadGroup"/>
        <exclude name="AvoidSynchronizedStatement"/>
        <exclude name="AvoidSynchronizedAtMethodLevel"/>
        <exclude name="UseConcurrentHashMap"/>
        <exclude name="AvoidUsingVolatile"/>
    </rule>
    
    <!-- Performance -->
    <rule ref="category/java/performance.xml">
        <exclude name="AvoidInstantiatingObjectsInLoops"/>
        <exclude name="RedundantFieldInitializer"/>
        <exclude name="InefficientEmptyStringCheck"/>
    </rule>
    
    <!-- Security -->
    <rule ref="category/java/security.xml"/>
    
    <!-- Exclude package-info files -->
    <exclude-pattern>.*/package-info\.java</exclude-pattern>

    <!-- Exclude classpath files -->
    <exclude-pattern>.*/classpath/.*</exclude-pattern>
    
</ruleset>
