<?xml version="1.0" encoding="UTF-8"?>
<ruleset xmlns="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0 https://www.mojohaus.org/versions-maven-plugin/xsd/rule-2.0.0.xsd"
         comparisonMethod="maven">
    
    <ignoreVersions>
        <ignoreVersion type="regex">.*[-_\.](alpha|Alpha|ALPHA|b|beta|Dev|Beta|BETA|rc|RC|M|EA|ea|SNAPSHOT)[-_.+]?[0-9]*</ignoreVersion>
    </ignoreVersions>
    
    <rules>
        <rule groupId="org.openjfx" artifactId="javafx-base" comparisonMethod="maven">
            <ignoreVersions>
                <ignoreVersion type="regex">.*[-_\.](alpha|Alpha|ALPHA|b|beta|Dev|Beta|BETA|rc|RC|M|EA|ea|SNAPSHOT)[-_.+]?[0-9]*</ignoreVersion>
                <ignoreVersion type="regex">2[3-9]\..*</ignoreVersion>
                <ignoreVersion type="regex">[3-9][0-9]\..*</ignoreVersion>
                <ignoreVersion type="regex">2[3-9]</ignoreVersion>
                <ignoreVersion type="regex">[3-9][0-9]</ignoreVersion>
                <ignoreVersion type="regex">2[3-9].*</ignoreVersion>
                <ignoreVersion type="regex">[3-9][0-9].*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.openjfx" artifactId="javafx-controls" comparisonMethod="maven">
            <ignoreVersions>
                <ignoreVersion type="regex">.*[-_\.](alpha|Alpha|ALPHA|b|beta|Dev|Beta|BETA|rc|RC|M|EA|ea|SNAPSHOT)[-_.+]?[0-9]*</ignoreVersion>
                <ignoreVersion type="regex">2[3-9]\..*</ignoreVersion>
                <ignoreVersion type="regex">[3-9][0-9]\..*</ignoreVersion>
                <ignoreVersion type="regex">2[3-9]</ignoreVersion>
                <ignoreVersion type="regex">[3-9][0-9]</ignoreVersion>
                <ignoreVersion type="regex">2[3-9].*</ignoreVersion>
                <ignoreVersion type="regex">[3-9][0-9].*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.openjfx" artifactId="javafx-graphics" comparisonMethod="maven">
            <ignoreVersions>
                <ignoreVersion type="regex">.*[-_\.](alpha|Alpha|ALPHA|b|beta|Dev|Beta|BETA|rc|RC|M|EA|ea|SNAPSHOT)[-_.+]?[0-9]*</ignoreVersion>
                <ignoreVersion type="regex">2[3-9]\..*</ignoreVersion>
                <ignoreVersion type="regex">[3-9][0-9]\..*</ignoreVersion>
                <ignoreVersion type="regex">2[3-9]</ignoreVersion>
                <ignoreVersion type="regex">[3-9][0-9]</ignoreVersion>
                <ignoreVersion type="regex">2[3-9].*</ignoreVersion>
                <ignoreVersion type="regex">[3-9][0-9].*</ignoreVersion>
            </ignoreVersions>
        </rule>
    </rules>
    
</ruleset>
